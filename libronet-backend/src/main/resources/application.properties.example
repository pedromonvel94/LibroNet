spring.application.name=libronet
server.port=8080

# Configuración de la base de datos PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/libro_net
spring.datasource.username=postgres
# Reemplaza 'tu_contrasena' por la contraseña local de tu PostgreSQL
spring.datasource.password=${DB_PASSWORD:tu_contrasena}
spring.datasource.driver-class-name=org.postgresql.Driver
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# Configuración de JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# Clave secreta para firmar tokens JWT (Genera una clave Base64 segura para producción)
security.jwt.secret-key=${JWT_SECRET:ClaveSecreta Base64}
